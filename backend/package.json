{
  "name": "cuda-platform-backend",
  "version": "1.0.0",
  "description": "Backend del sistema CUDA platform para ejecución remota de código CUDA.",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run start"
  },
  "keywords": [
    "cuda",
    "bullmq",
    "redis",
    "typescript",
    "nodejs",
    "express",
    "websocket",
    "gpu",
    "queue"
  ],
  "author": "Raúl Vázquez Rodríguez",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/socket.io": "^3.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
